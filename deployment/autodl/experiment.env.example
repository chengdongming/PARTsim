PARTSIM_ROOT=/path/to/PARTSim-project
PARTSIM_VENV=/path/to/PARTSim-project/.venv-autodl
PARTSIM_BUILD_DIR=/path/to/PARTSim-project/build
PARTSIM_OUTPUT_ROOT=/path/to/output/v9_3
PARTSIM_LOG_ROOT=/path/to/output/v9_3/logs
PARTSIM_WORKERS=4
PARTSIM_BUILD_JOBS=4
PARTSIM_MIN_MEMORY_GIB=2
PARTSIM_MIN_DISK_GIB=5

# Formal mode remains locked until final configuration review.
# CORE1_FORMAL_CONFIG=configs/v9_3_core1_formal_candidate.yaml
# CORE1_FORMAL_AUTHORIZATION=/path/to/core1_formal_authorization.json
# CORE2_FORMAL_CONFIG=configs/v9_3_core2_formal_candidate.yaml
# CORE2_FORMAL_AUTHORIZATION=/path/to/core2_formal_authorization.json
# CORE3_FORMAL_CONFIG=/path/to/frozen_core3.yaml
# CORE4_FORMAL_CONFIG=/path/to/frozen_core4.yaml
# CORE5_FORMAL_CONFIG=/path/to/frozen_core5.yaml
# EXT1_FORMAL_CONFIG=/path/to/frozen_ext1.yaml
# EXT4_FORMAL_CONFIG=/path/to/frozen_ext4.yaml
