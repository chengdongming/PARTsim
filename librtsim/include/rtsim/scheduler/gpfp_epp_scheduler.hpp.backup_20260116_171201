// gpfp_epp_scheduler.hpp - EPP (Energy-aware Preemptive Priority) Scheduler
// 算法设计文档：EPP_SCHEDULER_DESIGN.md

#ifndef RTSIM_GPFP_EPP_SCHEDULER_HPP
#define RTSIM_GPFP_EPP_SCHEDULER_HPP

#include "config_manager.hpp"
#include "energy_bridge.hpp"
#include "scheduler.hpp"
#include <metasim/event.hpp>
#include <metasim/factory.hpp>
#include <deque>
#include <map>
#include <string>
#include <vector>

namespace RTSim {

    using namespace MetaSim;

    // =====================================================
    // 前向声明
    // =====================================================

    class CPU;
    class AbsRTTask;
    class EPPScheduler;
    class TaskModel;

    // =====================================================
    // EPPEnergyRecoveryEvent - 能量恢复事件
    // =====================================================

    class EPPEnergyRecoveryEvent : public MetaSim::Event {
    private:
        EPPScheduler *_scheduler;

        friend class EPPScheduler;  // 允许访问私有成员

    public:
        EPPEnergyRecoveryEvent(EPPScheduler *scheduler);
        virtual void doit() override;
    };

    // =====================================================
    // EPPTaskModel - EPP任务模型
    // =====================================================

    class EPPTaskModel : public TaskModel {
    private:
        int _period;
        int _wcet;
        std::string _workload_type;
        double _energy_coefficient;
        Tick _rm_priority;

    public:
        EPPTaskModel(AbsRTTask *t, int period, int wcet,
                    const std::string &workload_type,
                    double energy_coefficient);
        virtual ~EPPTaskModel();

        // 实现TaskModel的纯虚函数
        virtual Tick getPriority() const override {
            return _rm_priority;
        }

        virtual void changePriority(Tick p) override {
            _rm_priority = p;
        }

        void setPeriod(int period);
        int getPeriod() const { return _period; }
        int getWCET() const { return _wcet; }
        const std::string& getWorkloadType() const { return _workload_type; }
        double getEnergyCoefficient() const { return _energy_coefficient; }
        Tick getRMPriority() const { return _rm_priority; }
    };

    // =====================================================
    // EPPScheduler - 能量感知抢占式优先级调度器
    // =====================================================

    class EPPScheduler : public Scheduler {
        // 友元类
        friend class EPPEnergyRecoveryEvent;
    private:
        // 能量管理
        double _current_energy;
        double _initial_energy;
        double _max_energy;

        // 队列管理
        std::deque<AbsRTTask *> _ready_queue;      // 就绪队列（RM优先级排序）
        std::deque<AbsRTTask *> _waiting_queue;    // 等待队列（能量不足）
        std::map<CPU *, AbsRTTask *> _running_tasks; // 运行任务映射

        // 能量恢复
        EPPEnergyRecoveryEvent *_recovery_event;

        // 配置管理
        ConfigManager *_config_manager;
        Tick _last_collection_time;

        // 太阳能配置
        double _pv_efficiency;
        double _pv_area_m2;
        std::string _solar_data_file;
        bool _use_real_solar_data;

        // 调度配置
        Tick _unit_time;                           // 单位时间（1 Tick = 1ms）
        bool _enable_energy_recovery;
        Tick _max_recovery_wait_time_ms;

        // 日志和调试
        std::string _name;

        // 任务模型存储
        std::map<AbsRTTask *, EPPTaskModel *> _task_models;

        // =====================================================
        // 内部辅助方法
        // =====================================================

        // 队列管理
        void addToReadyQueue(AbsRTTask *task);
        void addToWaitingQueue(AbsRTTask *task);
        void removeFromReadyQueue(AbsRTTask *task);
        void removeFromWaitingQueue(AbsRTTask *task);
        AbsRTTask *getHighestPriorityTaskFromReadyQueue();
        bool isInReadyQueue(AbsRTTask *task) const;
        bool isInWaitingQueue(AbsRTTask *task) const;

        // 能量计算
        double calculateEnergyForTask(AbsRTTask *task);
        double calculateEnergyForWCET(AbsRTTask *task, Tick wcet);
        double calculatePowerForWorkload(const std::string &workload, double frequency);

        // ⭐ 前瞻性能量判断（新逻辑）
        double predictEnergyCollection(Tick current_time, Tick duration);
        bool canScheduleWithEnergy(AbsRTTask *task, Tick current_time);

        // 能量收集
        double collectSolarEnergy(Tick current_time);
        double getSolarIrradiance(int64_t time_ms);
        Tick calculateEnergyRecoveryTime(double energy_needed);

        // 能量恢复管理
        void scheduleEnergyRecoveryEvent(Tick delay);
        void cancelEnergyRecoveryEvent();

        // ⭐ 能量扣减
        bool consumeEnergy(double energy_joules, const std::string &task_name);

        // 任务管理
        EPPTaskModel *getTaskModel(AbsRTTask *task);
        std::string getTaskName(AbsRTTask *task);

        // 抢占检查
        void checkAndPreemptOnAllCPUs();
        bool shouldPreempt(CPU *cpu, AbsRTTask *new_task);

        // 调度辅助
        int getFreeCPUCount();
        CPU *getFreeCPU();
        void dispatchTask(AbsRTTask *task, CPU *cpu);

    public:
        // =====================================================
        // 构造函数和析构函数
        // =====================================================

        EPPScheduler();
        EPPScheduler(const std::vector<std::string> &params);
        virtual ~EPPScheduler();

        // 工厂方法
        static std::unique_ptr<EPPScheduler>
            createInstance(const std::vector<std::string> &params);

        // =====================================================
        // 核心调度接口
        // =====================================================

        // 主调度函数（不使用override，因为基类Scheduler没有schedule()）
        void schedule();

        // 添加任务
        void addTask(AbsRTTask *task, const std::string &params) override;

        // 移除任务
        void removeTask(AbsRTTask *task) override;

        // 获取第一个要调度的任务（实现能量约束）
        AbsRTTask *getFirst() override;

        // 获取第n个要调度的任务（实现级联调度）
        AbsRTTask *getTaskN(unsigned int n) override;

        // 任务到达事件处理
        void onTaskArrival(AbsRTTask *task);

        // Tick级抢占检查
        void checkAndPreempt();

        // =====================================================
        // 能量管理接口
        // =====================================================

        double getCurrentEnergy() const { return _current_energy; }
        void setCurrentEnergy(double energy) { _current_energy = energy; }
        double getInitialEnergy() const { return _initial_energy; }
        double getMaxEnergy() const { return _max_energy; }

        // 充值能量（用于测试）
        void rechargeEnergy(double amount) {
            _current_energy = std::min(_current_energy + amount, _max_energy);
        }

        // =====================================================
        // 队列管理接口
        // =====================================================

        // 从等待队列恢复到就绪队列
        void restoreWaitingQueueToReadyQueue();

        // 获取队列状态
        size_t getReadyQueueSize() const { return _ready_queue.size(); }
        size_t getWaitingQueueSize() const { return _waiting_queue.size(); }
        bool isReadyQueueEmpty() const { return _ready_queue.empty(); }
        bool isWaitingQueueEmpty() const { return _waiting_queue.empty(); }

        // =====================================================
        // 配置接口
        // =====================================================

        void setUnitTime(Tick unit_time) { _unit_time = unit_time; }
        Tick getUnitTime() const { return _unit_time; }

        void setPVConfig(double efficiency, double area, const std::string &solar_file);
        void setUseRealSolarData(bool use) { _use_real_solar_data = use; }

        // =====================================================
        // 状态查询
        // =====================================================

        const std::string& getName() const { return _name; }
        void setName(const std::string &name) { _name = name; }

        // 获取运行中的任务
        AbsRTTask *getRunningTaskOnCPU(CPU *cpu);
        const std::map<CPU *, AbsRTTask *>& getRunningTasks() const {
            return _running_tasks;
        }
    };

} // namespace RTSim

// =====================================================
// 工厂注册
// =====================================================

namespace RTSim {
    static registerInFactory<RTSim::Scheduler, RTSim::EPPScheduler>
        registerEPPEnergy("gpfp_epp");
}

#endif // RTSIM_GPFP_EPP_SCHEDULER_HPP
